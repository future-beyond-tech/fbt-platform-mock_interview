# Optional — backend URL (default: http://localhost:8000)
VITE_API_URL=http://localhost:8000

# Frontend API keys are configured in-app via the settings drawer.
# Do not put provider keys in Vite env vars.

# Backend CORS allow-list (comma-separated)
# BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional backend provider keys
# GROQ_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
